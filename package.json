{
  "name": "@hypeserv/mcmp-installer",
  "version": "1.1.3",
  "description": "hypeServ Minecraft modpack installer. Pulls a modpack from a URL, extracts it, installs the loader, and prepares the server for boot.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "mcmp-installer": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && chmod +x dist/cli.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypeserv/mcmp-installer.git"
  },
  "homepage": "https://hypeserv.com",
  "bugs": {
    "url": "https://github.com/hypeserv/mcmp-installer/issues"
  },
  "keywords": [
    "minecraft",
    "modpack",
    "installer",
    "forge",
    "neoforge",
    "fabric",
    "curseforge",
    "modrinth",
    "ftb",
    "technic",
    "hypeserv"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.7.0",
    "cli-progress": "^3.12.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.5.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/cli-progress": "^3.11.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/yargs": "^17.0.32",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
